# --- Required ---
GEMINI_API_KEY=your_google_gemini_api_key_here

# --- LLM / embeddings ---
# Primary chat model. If it hits its daily free-tier cap, the app automatically
# rolls over to LLM_FALLBACKS (in order).
LLM_MODEL=gemini-flash-latest
LLM_FALLBACKS=gemini-2.0-flash,gemini-2.5-flash,gemini-flash-lite-latest
EMBEDDING_MODEL=models/gemini-embedding-001

# NOTE on free-tier limits: Gemini's free tier caps requests-per-day *per model*.
# One full interview is ~9-12 model calls. If you see "rating derived from live
# assessments" or slow/refused turns, you've hit the daily cap — wait for the
# reset, use a key with billing enabled, or lower MAX_QUESTIONS below.

# --- Storage (optional overrides) ---
# DATABASE_URL=sqlite:///./storage/app.db
# CHROMA_DIR=./storage/chroma
# KB_DIR=./knowledge_base

# --- RAG tuning ---
CHUNK_SIZE=1000
CHUNK_OVERLAP=150
RETRIEVAL_K=5

# --- Interview behaviour (adaptive agent) ---
NUM_TOPICS=4                 # distinct topics in the coverage plan
MAX_QUESTIONS=6              # hard cap on total questions (topics + follow-ups)
MAX_FOLLOWUPS_PER_TOPIC=2    # how deep a single topic can be probed

# --- CORS: frontend origins (comma-separated) ---
CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173
